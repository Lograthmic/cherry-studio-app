{
  "name": "cherry-studio-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:clear": "expo start --dev-client --clear",
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios",
    "prebuild": "expo prebuild",
    "db:generate": "drizzle-kit generate",
    "generate:icons": "tsx packages/lucide-uniwind/scripts/generate-icons.ts",
    "ui:icons:generate": "pnpm ui:icons:generate:svg && pnpm ui:provider-icons:generate",
    "ui:icons:generate:svg": "tsx packages/ui/src/scripts/generate-icons.ts",
    "ui:icons:generate:general": "tsx packages/ui/src/scripts/generate-icons.ts --type=general",
    "ui:icons:generate:models": "tsx packages/ui/src/scripts/generate-icons.ts --type=models",
    "ui:provider-icons:generate": "tsx packages/ui/src/scripts/generate-provider-icons.ts",
    "prototype:chat-conversation": "tsx src/components/chat/prototype/chat-conversation-prototype.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "e2e:ios": "maestro test --platform ios .maestro/flows",
    "e2e:ios:debug": "maestro test --platform ios --debug-output artifacts/e2e .maestro/flows",
    "e2e:ios:flow": "maestro test --platform ios",
    "e2e:maestro:check": "for f in .maestro/flows/*.yaml; do maestro check-syntax \"$f\" || exit 1; done"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/cerebras": "^2.0.54",
    "@ai-sdk/gateway": "^3.0.121",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/huggingface": "^1.0.50",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/perplexity": "^3.0.33",
    "@ai-sdk/provider": "3.0.10",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@ai-sdk/togetherai": "^2.0.53",
    "@ai-sdk/xai": "^3.0.92",
    "@babel/runtime": "^7.29.2",
    "@cherrystudio/ai-core": "workspace:*",
    "@cherrystudio/ai-sdk-provider": "workspace:*",
    "@cherrystudio/provider-registry": "workspace:*",
    "@cherrystudio/ui": "workspace:*",
    "@expo/dom-webview": "^56.0.5",
    "@expo/ui": "~56.0.12",
    "@legendapp/list": "3.0.0-beta.55",
    "@magrinj/expo-quick-look": "^0.3.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tanstack/react-query": "^5.100.10",
    "ai": "^6.0.143",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.3",
    "expo-auth-session": "~56.0.13",
    "expo-build-properties": "~56.0.13",
    "expo-clipboard": "^56.0.3",
    "expo-constants": "~56.0.14",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.14",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.8",
    "expo-image-picker": "~56.0.12",
    "expo-intent-launcher": "~56.0.4",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-media-library": "~56.0.6",
    "expo-router": "~56.2.5",
    "expo-speech-recognition": "56.0.0",
    "expo-splash-screen": "~56.0.9",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "fractional-indexing": "^3.2.0",
    "heroui-native": "^1.0.3",
    "i18next": "^26.1.0",
    "katex": "0.17.0",
    "lucide-uniwind": "workspace:*",
    "ratex-react-native": "^0.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.7",
    "react-native": "0.85.3",
    "react-native-enriched-markdown": "0.6.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-streamdown": "0.2.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "remend": "1.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "uniwind": "^1.6.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@biomejs/biome": "^2.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.7.0",
    "@types/react": "~19.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "~56.0.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "lucide": "^1.14.0",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "react-native-svg": "15.15.4"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "@magrinj/expo-quick-look@0.3.1": "patches/@magrinj__expo-quick-look@0.3.1.patch"
    }
  }
}
