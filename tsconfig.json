{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest"],
    "paths": {
      "@cherrystudio/provider-registry": ["./packages/provider-registry/src/index.ts"],
      "@cherrystudio/provider-registry/mobile": [
        "./packages/provider-registry/src/mobileLoader.ts"
      ],
      "@cherrystudio/provider-registry/*": ["./packages/provider-registry/src/*"],
      "@cherrystudio/ui": ["./packages/ui/src/index.ts"],
      "@cherrystudio/ui/*": ["./packages/ui/src/*"],
      "lucide-uniwind": ["./packages/lucide-uniwind/src/index.ts"],
      "lucide-uniwind/*": ["./packages/lucide-uniwind/src/*"],
      "@src/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
