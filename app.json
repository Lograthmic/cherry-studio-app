{
  "expo": {
    "name": "Cherry Studio",
    "slug": "cherry-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cherry-studio",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.cherry-ai.cherry-studio-app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F65D5D"
      },
      "package": "com.cherry_ai.cherry_studio_app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#000000"
          },
          "android": {
            "image": "./assets/icon.png",
            "imageWidth": 76,
            "dark": {
              "image": "./assets/icon.png",
              "backgroundColor": "#000000"
            }
          }
        }
      ],
      "expo-localization",
      "expo-sqlite",
      "expo-document-picker",
      "expo-font",
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Cherry Studio to preview and select photos for chat messages.",
          "cameraPermission": "Allow Cherry Studio to open the camera for chat messages.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Cherry Studio to preview photos for chat messages.",
          "savePhotosPermission": "Allow Cherry Studio to save photos.",
          "preventAutomaticLimitedAccessAlert": true,
          "granularPermissions": ["photo"]
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "80096eaf-3ad0-4b87-a466-15f04da1bacc"
      }
    }
  }
}
