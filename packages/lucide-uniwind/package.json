{
  "name": "lucide-uniwind",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./png": {
      "types": "./src/png-icons/index.ts",
      "react-native": "./src/png-icons/index.ts",
      "import": "./src/png-icons/index.ts",
      "default": "./src/png-icons/index.ts"
    },
    "./png/generated/*": {
      "types": "./src/png-icons/generated/*.tsx",
      "react-native": "./src/png-icons/generated/*.tsx",
      "import": "./src/png-icons/generated/*.tsx",
      "default": "./src/png-icons/generated/*.tsx"
    }
  },
  "scripts": {
    "icons:generate": "tsx scripts/generate-icons.ts",
    "icons:generate:png": "tsx scripts/generate-png-icons.ts"
  },
  "dependencies": {
    "lucide-react-native": "^1.14.0"
  },
  "peerDependencies": {
    "expo-image": "*",
    "react": "*",
    "uniwind": "*"
  }
}
