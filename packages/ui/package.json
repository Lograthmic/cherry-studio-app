{
  "name": "@cherrystudio/ui",
  "version": "0.0.1-alpha.1",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "icons:generate": "pnpm icons:generate:svg && pnpm provider-icons:generate",
    "icons:generate:svg": "tsx src/scripts/generate-icons.ts",
    "icons:generate:general": "tsx src/scripts/generate-icons.ts --type=general",
    "icons:generate:models": "tsx src/scripts/generate-icons.ts --type=models",
    "provider-icons:generate": "tsx src/scripts/generate-provider-icons.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./icons": {
      "types": "./src/icons/index.ts",
      "react-native": "./src/icons/index.ts",
      "import": "./src/icons/index.ts",
      "default": "./src/icons/index.ts"
    },
    "./icons-png": {
      "types": "./src/icons-png/index.ts",
      "react-native": "./src/icons-png/index.ts",
      "import": "./src/icons-png/index.ts",
      "default": "./src/icons-png/index.ts"
    },
    "./icons-png/providers": {
      "types": "./src/icons-png/providers/index.ts",
      "react-native": "./src/icons-png/providers/index.ts",
      "import": "./src/icons-png/providers/index.ts",
      "default": "./src/icons-png/providers/index.ts"
    },
    "./icons-png/*": {
      "types": "./src/icons-png/*",
      "react-native": "./src/icons-png/*",
      "import": "./src/icons-png/*",
      "default": "./src/icons-png/*"
    },
    "./icons/general": {
      "types": "./src/icons/general/index.ts",
      "react-native": "./src/icons/general/index.ts",
      "import": "./src/icons/general/index.ts",
      "default": "./src/icons/general/index.ts"
    },
    "./icons/models": {
      "types": "./src/icons/models/index.ts",
      "react-native": "./src/icons/models/index.ts",
      "import": "./src/icons/models/index.ts",
      "default": "./src/icons/models/index.ts"
    }
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-svg": "*",
    "uniwind": "*"
  }
}
